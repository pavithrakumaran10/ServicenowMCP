# ServiceNow PDI connection
SN_URL=https://devXXXXXX.service-now.com

# Basic auth (simplest; fine for a PDI demo)
SN_USER=admin
SN_PASS=your_password

# OAuth2 (preferred — register an OAuth app in your PDI, then fill these in).
# When all four are set, the client uses OAuth instead of Basic auth.
SN_CLIENT_ID=
SN_CLIENT_SECRET=

# All MCP writes land here, never in Default
SN_UPDATE_SET=MCP Automated Changes
